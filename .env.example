# Gmail OAuth2 — download from Google Cloud Console
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL — provided automatically by Railway
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Scheduler
POLL_INTERVAL_MINUTES=15
FOLLOWUP_DELAY_DAYS=2
MAX_FOLLOWUPS_PER_STAGE=2

# Campaign defaults (FALLBACKS ONLY).
# Brand name and deadline are per-campaign and stored per-creator (set at seed
# time via `seed.py --brand / --deadline`). These env vars are used only when a
# creator was seeded without a brand/deadline — so one backend can negotiate for
# many brands at once. Leave them as sensible defaults.
MANAGER_NAME=Jennifer
BRAND_NAME=Reve
CAMPAIGN_DEADLINE=February 05, 2026

# Claude model (optional override)
CLAUDE_MODEL=claude-opus-4-8

# Instagram Scraper (Playwright)
# Run login.py locally, then login.py --upload to get INSTAGRAM_AUTH_B64
INSTAGRAM_AUTH_B64=<base64-encoded instagram_auth.json, see login.py --upload>
INSTAGRAM_AUTH_FILE=/tmp/instagram_auth.json
SCRAPER_HEADLESS=true
SCRAPER_NUM_REELS=12
SCRAPER_SCROLL_PAUSE_MS=2000
SCRAPER_TIMEOUT_S=60

# CPM Pricing (mirrors Chrome extension defaults)
TARGET_CPM=15
RISK_BUFFER=0.20
NUM_VIDEOS=2
BONUS_PERCENTAGE=0.20

# Max CPM cap for 6 AI-suggested offers (defaults to TARGET_CPM if unset)
MAX_CPM=15

# Outreach Email Automation integration
# Set OUTREACH_API_URL to push IG data + offers to the outreach dashboard, and
# to pull the campaign's max_cpm + the admin's approved offer back.
# OUTREACH_API_TOKEN must match NEGOTIATION_API_TOKEN in the outreach backend.
OUTREACH_API_URL=https://your-outreach-backend.railway.app
OUTREACH_API_TOKEN=your-shared-secret-token

# Human-in-the-loop approval gate.
# true  = after a creator shares their rate, wait for an admin to approve an
#         offer in the dashboard before sending the offer email (Reply 2).
# false = send Reply 2 immediately (approved offer if one exists, else A/B/C).
# Only takes effect when OUTREACH_API_URL is set and the creator exists in the dashboard.
REQUIRE_OFFER_APPROVAL=true
